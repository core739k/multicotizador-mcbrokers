@page
@model McBrokers.Web.Pages.Admin.Agents.IndexModel
@using McBrokers.Domain.Agents
@{
    ViewData["Title"] = "Agentes";
}

<h2>Agentes</h2>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (!Model.Agents.Any())
{
    <p class="text-muted">No hay agentes registrados. Los agentes se provisionan automáticamente al iniciar sesión con Google.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Nombre</th>
                <th>Email</th>
                <th>Rol</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var agent in Model.Agents)
            {
                <tr>
                    <td>@agent.FullName</td>
                    <td><code>@agent.Email</code></td>
                    <td>
                        <form method="post" asp-page-handler="Role" class="d-flex gap-2">
                            <input type="hidden" name="AgentId" value="@agent.Id" />
                            <select name="Role" class="form-select form-select-sm" style="width:auto;">
                                @foreach (var role in Enum.GetValues<AgentRole>())
                                {
                                    if (role == agent.Role)
                                    {
                                        <option value="@role" selected>@role</option>
                                    }
                                    else
                                    {
                                        <option value="@role">@role</option>
                                    }
                                }
                            </select>
                            <button type="submit" class="btn btn-sm btn-outline-primary">Guardar</button>
                        </form>
                    </td>
                    <td>
                        @if (agent.IsActive)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactivo</span>
                        }
                    </td>
                    <td>
                        <form method="post" asp-page-handler="Active">
                            <input type="hidden" name="AgentId" value="@agent.Id" />
                            <input type="hidden" name="IsActive" value="@(!agent.IsActive)" />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">
                                @(agent.IsActive ? "Desactivar" : "Reactivar")
                            </button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
