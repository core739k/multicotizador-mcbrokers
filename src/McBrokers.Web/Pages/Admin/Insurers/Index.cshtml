@page
@model McBrokers.Web.Pages.Admin.Insurers.IndexModel
@{
    ViewData["Title"] = "Aseguradoras";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Aseguradoras</h2>
    <a class="btn btn-primary" asp-page="./Create">Nueva aseguradora</a>
</div>

@if (!Model.Insurers.Any())
{
    <p class="text-muted">No hay aseguradoras configuradas.</p>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>Orden</th>
                <th>Código</th>
                <th>Nombre</th>
                <th>Estado</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var insurer in Model.Insurers)
            {
                <tr>
                    <td>@insurer.DisplayOrder</td>
                    <td><code>@insurer.Code</code></td>
                    <td>@insurer.Name</td>
                    <td>
                        @if (insurer.IsEnabled)
                        {
                            <span class="badge bg-success">Activa</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Inactiva</span>
                        }
                    </td>
                    <td><a class="btn btn-sm btn-outline-secondary" asp-page="./Edit" asp-route-id="@insurer.Id">Editar</a></td>
                </tr>
            }
        </tbody>
    </table>
}
