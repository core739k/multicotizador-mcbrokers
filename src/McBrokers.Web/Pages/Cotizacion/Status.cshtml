@page "{id:guid}"
@model McBrokers.Web.Pages.Cotizacion.StatusModel
@using McBrokers.Application.Quotations
@using McBrokers.Domain.Insurers
@using McBrokers.Domain.Quotations
@{
    ViewData["Title"] = $"Cotización {Model.View?.Id.ToString().Substring(0, 8) ?? ""}";
}

@if (Model.View is null)
{
    <p class="text-muted">Cotización no encontrada.</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        @if (Model.View.Vehicle is not null)
        {
            var v = Model.View.Vehicle;
            <h2 class="mb-0">COTIZACIÓN DEL VEHÍCULO @v.Year @v.Brand @v.Model @v.Version</h2>
        }
        else
        {
            @* Vehicle puede ser null si el master fue borrado del catálogo
               después de cotizar. Fallback al correlation-id como referencia. *@
            <h2 class="mb-0">Cotización <code>@Model.View.CorrelationId</code></h2>
        }
        <span class="badge bg-@StatusColor(Model.View.Status) fs-6">@StatusLabels.Spanish(Model.View.Status)</span>
    </div>

    <p class="text-muted">
        @Model.View.Results.Count de @Model.View.ExpectedResultsCount aseguradoras respondieron.
    </p>

    @if (!string.IsNullOrWhiteSpace(Model.RequoteError))
    {
        <div class="alert alert-danger">@Model.RequoteError</div>
    }

    @if (Model.View.Results.Count == 0)
    {
        <div class="alert alert-info">
            Esperando respuesta de las aseguradoras… <span class="spinner-border spinner-border-sm"></span>
        </div>
    }
    else
    {
        @* Tarjetas horizontales — una por aseguradora. Selects editables
           recotizan esa aseguradora al cambiar (form submit on change). *@
        @foreach (var r in Model.View.Results)
        {
            // Valores efectivos: overrides previos si existen, sino base de la Quotation.
            var effVehicleId = r.Overrides?.VehicleMasterId ?? Model.View.BaseVehicleMasterId;
            var effValuation = r.Overrides?.Valuation ?? Model.View.BaseValuationType;
            var effDMPct = r.Overrides?.MaterialDamagesDeductiblePct
                           ?? Model.View.Deducibles?.MaterialDamagesDeductiblePct;
            var effRTPct = r.Overrides?.RobberyDeductiblePct
                           ?? Model.View.Deducibles?.RobberyDeductiblePct;
            var effGMO = r.Overrides?.MedicalExpensesSumInsured
                         ?? Model.View.Deducibles?.MedicalExpensesSumInsured;
            var rcMonto = Model.View.Deducibles?.CivilLiabilitySumInsured;

            <div class="card mb-3 @(r.Status == QuotationInsurerStatus.Succeeded ? "border-success" : "border-danger")">
                <div class="card-body py-3">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title mb-0 d-flex align-items-center gap-2">
                            @if (!string.IsNullOrWhiteSpace(r.InsurerLogoUrl))
                            {
                                <img src="@r.InsurerLogoUrl" alt="@(r.InsurerName ?? "Aseguradora")"
                                     class="quote-result-logo" />
                            }
                            <span>@(r.InsurerName ?? "Aseguradora")</span>
                            <span class="badge bg-@StatusColor(r.Status) ms-2">@StatusLabels.Spanish(r.Status)</span>
                            @if (r.Version > 1)
                            {
                                <span class="badge bg-info text-dark">v@(r.Version)</span>
                            }
                        </h5>
                        @if (r.Status == QuotationInsurerStatus.Succeeded)
                        {
                            <a class="btn btn-sm btn-success" asp-page="/Emision/Index" asp-route-resultId="@r.Id">
                                Emitir póliza
                            </a>
                        }
                    </div>

                    @if (r.Status == QuotationInsurerStatus.Succeeded)
                    {
                        @* Una form por card. Cada select hace submit on change y manda
                           los 5 overrides — los hidden inputs preservan los no tocados.
                           El nombre de los campos corresponde a OnPostRequoteAsync. *@
                        <form method="post" asp-page-handler="Requote"
                              asp-route-id="@Model.View.Id"
                              asp-route-insurerId="@r.InsurerId"
                              class="row g-2 align-items-end mb-2">

                            @* col-md-auto + nowrap: col-md-1 (~80px) recortaba el
                               último dígito de montos como $23,456.78 y lo
                               envolvía a la línea siguiente. auto deja que la
                               columna crezca al ancho real del monto. *@
                            <div class="col-md-auto" style="white-space: nowrap;">
                                <div class="text-muted small">Prima total</div>
                                <div class="fw-bold fs-5">$@r.PremiumTotal?.ToString("N2")</div>
                            </div>

                            <div class="col-md-3">
                                <label class="form-label text-muted small mb-1">Versión</label>
                                <select name="vehicleMasterId" class="form-select form-select-sm"
                                        onchange="this.form.submit()">
                                    @foreach (var v in Model.AvailableVehicleVersions)
                                    {
                                        if (v.Id == effVehicleId)
                                        {
                                            <option value="@v.Id" selected>@v.Version</option>
                                        }
                                        else
                                        {
                                            <option value="@v.Id">@v.Version</option>
                                        }
                                    }
                                    @if (Model.AvailableVehicleVersions.Count == 0 && Model.View.Vehicle is not null)
                                    {
                                        <option value="@effVehicleId" selected>@Model.View.Vehicle.Version</option>
                                    }
                                </select>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label text-muted small mb-1">Valor</label>
                                <select name="valuation" class="form-select form-select-sm"
                                        onchange="this.form.submit()">
                                    @foreach (var vt in Enum.GetValues<ValuationType>())
                                    {
                                        if (vt == effValuation)
                                        {
                                            <option value="@vt" selected>@SpanishValuation(vt)</option>
                                        }
                                        else
                                        {
                                            <option value="@vt">@SpanishValuation(vt)</option>
                                        }
                                    }
                                </select>
                            </div>

                            @* AXA DXN tiene valores fijos por aseguradora: DM=5%, RT=10%.
                               Hasta tener los catálogos de MySQL (cat_deducibles +
                               rel_deducible_valor_estimado), las otras aseguradoras usan
                               la lista global de DefaultCoverages. *@
                            @if (r.InsurerCode == InsurerCode.AxaDxn)
                            {
                                <div class="col-md-2">
                                    <label class="form-label text-muted small mb-1">Daños Materiales</label>
                                    <input type="text" class="form-control form-control-sm"
                                           value="@FormatPercent(effDMPct)" readonly tabindex="-1" />
                                    <input type="hidden" name="dmPct" value="@effDMPct" />
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label text-muted small mb-1">Robo Total</label>
                                    <input type="text" class="form-control form-control-sm"
                                           value="@FormatPercent(effRTPct)" readonly tabindex="-1" />
                                    <input type="hidden" name="rtPct" value="@effRTPct" />
                                </div>
                            }
                            else
                            {
                                <div class="col-md-2">
                                    <label class="form-label text-muted small mb-1">Daños Materiales</label>
                                    <select name="dmPct" class="form-select form-select-sm"
                                            onchange="this.form.submit()">
                                        @foreach (var d in Model.AvailableDMPct)
                                        {
                                            if (d == effDMPct)
                                            {
                                                <option value="@d" selected>@d%</option>
                                            }
                                            else
                                            {
                                                <option value="@d">@d%</option>
                                            }
                                        }
                                    </select>
                                </div>

                                <div class="col-md-2">
                                    <label class="form-label text-muted small mb-1">Robo Total</label>
                                    <select name="rtPct" class="form-select form-select-sm"
                                            onchange="this.form.submit()">
                                        @foreach (var d in Model.AvailableRTPct)
                                        {
                                            if (d == effRTPct)
                                            {
                                                <option value="@d" selected>@d%</option>
                                            }
                                            else
                                            {
                                                <option value="@d">@d%</option>
                                            }
                                        }
                                    </select>
                                </div>
                            }

                            <div class="col-md-2">
                                <label class="form-label text-muted small mb-1">Gastos Médicos Ocupantes</label>
                                <select name="gmo" class="form-select form-select-sm"
                                        onchange="this.form.submit()">
                                    @foreach (var g in Model.AvailableGMO)
                                    {
                                        if (g == effGMO)
                                        {
                                            <option value="@g" selected>$@g.ToString("N0")</option>
                                        }
                                        else
                                        {
                                            <option value="@g">$@g.ToString("N0")</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="col-md-2">
                                <label class="form-label text-muted small mb-1">Responsabilidad Civil</label>
                                <input type="text" class="form-control form-control-sm"
                                       value="@FormatMoney(rcMonto)" readonly tabindex="-1" />
                            </div>
                        </form>

                        @if (r.CoverageBadges.Count > 0)
                        {
                            <div class="mt-2 d-flex flex-wrap gap-1">
                                @foreach (var badge in r.CoverageBadges)
                                {
                                    var cls = badge.Amparado ? "bg-success" : "bg-secondary";
                                    <span class="badge @cls">@badge.Label: @(badge.Amparado ? "Amparado" : "No amparado")</span>
                                }
                            </div>
                        }
                        @* Desglose de prima — mismo estilo de label+input readonly que
                           los selectores de cobertura para alineación visual. *@
                        <div class="row g-2 mt-2">
                            <div class="col-md-2">
                                <label class="form-label text-muted small mb-1">Prima neta</label>
                                <input type="text" class="form-control form-control-sm"
                                       value="$@r.PremiumNet?.ToString("N2")" readonly tabindex="-1" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label text-muted small mb-1">IVA</label>
                                <input type="text" class="form-control form-control-sm"
                                       value="$@r.Tax?.ToString("N2")" readonly tabindex="-1" />
                            </div>
                            <div class="col-md-2">
                                <label class="form-label text-muted small mb-1">Derechos</label>
                                <input type="text" class="form-control form-control-sm"
                                       value="$@r.Fees?.ToString("N2")" readonly tabindex="-1" />
                            </div>
                        </div>
                        <div class="text-muted small mt-1">@r.LatencyMs ms</div>
                    }
                    else
                    {
                        <p class="text-muted small mb-1">
                            <strong>@r.ErrorCategory</strong> — <code>@r.ErrorCode</code>
                        </p>
                        <p class="mb-0">@r.ErrorMessage</p>
                    }
                </div>
            </div>
        }
    }
}

@section Scripts {
    @if (Model.View?.Status is QuotationStatus.Pending or QuotationStatus.Partial)
    {
        <script>
            setTimeout(function () { window.location.reload(); }, 2000);
        </script>
    }
}

@functions {
    private static string StatusColor(QuotationStatus s) => s switch
    {
        QuotationStatus.Completed => "success",
        QuotationStatus.Partial => "warning text-dark",
        QuotationStatus.Failed => "danger",
        _ => "secondary",
    };

    private static string StatusColor(QuotationInsurerStatus s) => s switch
    {
        QuotationInsurerStatus.Succeeded => "success",
        QuotationInsurerStatus.Timeout => "warning text-dark",
        QuotationInsurerStatus.InsurerDown => "danger",
        QuotationInsurerStatus.NotCovered => "secondary",
        _ => "danger",
    };

    private static string FormatPercent(decimal? value) =>
        value is null ? "—" : $"{value.Value:0.##}%";

    private static string FormatMoney(decimal? value) =>
        value is null ? "—" : $"${value.Value:N0}";

    private static string SpanishValuation(ValuationType v) => v switch
    {
        ValuationType.Commercial => "Comercial",
        ValuationType.CommercialPlus10 => "Comercial + 10%",
        ValuationType.Agreed => "Convenido",
        ValuationType.AgreedPlus10 => "Convenido + 10%",
        ValuationType.Invoice => "Valor Factura",
        _ => v.ToString(),
    };
}
