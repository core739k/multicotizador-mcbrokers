@page
@model McBrokers.Web.Pages.Cotizacion.IndexModel
@using McBrokers.Domain.Quotations
@{
    ViewData["Title"] = "Nueva cotización";
}

<h2>Nueva cotización</h2>

<p class="text-muted small">
    Mostrando vehículos del año <strong>@Model.EffectiveYear</strong>.
    Cambia con <code>?year=2024</code> en la URL.
</p>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post" class="mt-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <h4>Vehículo</h4>
    <div class="mb-3">
        <label asp-for="Input.VehicleMasterId" class="form-label">Vehículo (master)</label>
        @if (Model.AvailableVehicles.Count == 0)
        {
            <div class="alert alert-warning">
                No hay vehículos en el catálogo. Carga datos en <a asp-page="/Admin/Catalog/Pending">Admin · Catálogo</a> primero.
            </div>
        }
        else
        {
            <select asp-for="Input.VehicleMasterId" class="form-select">
                @foreach (var v in Model.AvailableVehicles)
                {
                    <option value="@v.Id">@v.Year @v.Brand @v.Model — @v.Version</option>
                }
            </select>
        }
    </div>

    <h4 class="mt-4">Cotización</h4>
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="Input.Package" class="form-label">Paquete</label>
            <select asp-for="Input.Package" class="form-select">
                @foreach (var p in Enum.GetValues<PackageCode>())
                {
                    <option value="@p">@p</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.PaymentMode" class="form-label">Forma de pago</label>
            <select asp-for="Input.PaymentMode" class="form-select">
                @foreach (var p in Enum.GetValues<PaymentMode>())
                {
                    <option value="@p">@p</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.ValuationType" class="form-label">Tipo de valor</label>
            <select asp-for="Input.ValuationType" class="form-select">
                @foreach (var v in Enum.GetValues<ValuationType>())
                {
                    <option value="@v">@v</option>
                }
            </select>
        </div>
        <div class="col-md-4">
            <label asp-for="Input.SumInsured" class="form-label">Suma asegurada (MXN)</label>
            <input type="number" step="0.01" min="0.01" asp-for="Input.SumInsured" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Input.PostalCode" class="form-label">Código Postal</label>
            <input asp-for="Input.PostalCode" class="form-control" maxlength="5" pattern="\d{5}" />
        </div>
    </div>

    <h4 class="mt-4">Cliente</h4>
    <div class="row g-3">
        <div class="col-md-4">
            <label asp-for="Input.FirstName" class="form-label">Nombre</label>
            <input asp-for="Input.FirstName" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Input.LastNamePaternal" class="form-label">Apellido paterno</label>
            <input asp-for="Input.LastNamePaternal" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Input.LastNameMaternal" class="form-label">Apellido materno</label>
            <input asp-for="Input.LastNameMaternal" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Input.DateOfBirth" class="form-label">Fecha de nacimiento</label>
            <input type="date" asp-for="Input.DateOfBirth" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Input.Gender" class="form-label">Género</label>
            <select asp-for="Input.Gender" class="form-select">
                <option value="Male">Masculino</option>
                <option value="Female">Femenino</option>
            </select>
        </div>
    </div>

    <button type="submit" class="btn btn-primary mt-4" @(Model.AvailableVehicles.Count == 0 ? "disabled" : "")>
        Cotizar
    </button>
</form>
