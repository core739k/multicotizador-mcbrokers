@page "{resultId:guid}"
@model McBrokers.Web.Pages.Emision.IndexModel
@{
    ViewData["Title"] = "Emitir póliza";
}

<h2>Emitir póliza</h2>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<form method="post">
        <input type="hidden" asp-for="Input.QuotationInsurerResultId" />

        @* Resumen de errores de ModelState — sin esto la página re-renderiza
           silenciosamente cuando un [Required] o regex falla y el vendedor
           cree que el botón "no hace nada". *@
        <div asp-validation-summary="All" class="alert alert-danger" role="alert"
             style="display:none">
        </div>
        @* Bootstrap no oculta el alert si está vacío — un truquito JS al final
           del form lo muestra solo si tiene contenido. *@

        <h4>Cliente</h4>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Input.FirstName" class="form-label">Nombre</label>
                <input asp-for="Input.FirstName" class="form-control" required />
                <span asp-validation-for="Input.FirstName" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.LastNamePaternal" class="form-label">Apellido paterno</label>
                <input asp-for="Input.LastNamePaternal" class="form-control" required />
                <span asp-validation-for="Input.LastNamePaternal" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.LastNameMaternal" class="form-label">Apellido materno</label>
                <input asp-for="Input.LastNameMaternal" class="form-control" />
            </div>
            <div class="col-md-4">
                <label asp-for="Input.Rfc" class="form-label">RFC (12 o 13 caracteres)</label>
                <input asp-for="Input.Rfc" class="form-control" maxlength="13" required />
                <span asp-validation-for="Input.Rfc" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.Phone" class="form-label">Teléfono (10 dígitos)</label>
                <input asp-for="Input.Phone" class="form-control" pattern="\d{10}" required />
                <span asp-validation-for="Input.Phone" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.Email" class="form-label">Email</label>
                <input asp-for="Input.Email" type="email" class="form-control" required />
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>
        </div>

        <h4 class="mt-4">Domicilio</h4>
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Input.Street" class="form-label">Calle</label>
                <input asp-for="Input.Street" class="form-control" required />
                <span asp-validation-for="Input.Street" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Input.ExteriorNumber" class="form-label">N° Ext.</label>
                <input asp-for="Input.ExteriorNumber" class="form-control" required />
                <span asp-validation-for="Input.ExteriorNumber" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Input.InteriorNumber" class="form-label">N° Int.</label>
                <input asp-for="Input.InteriorNumber" class="form-control" />
            </div>
            <div class="col-md-3">
                <label asp-for="Input.PostalCode" class="form-label">Código postal</label>
                <input asp-for="Input.PostalCode" class="form-control" pattern="\d{5}" required
                       id="cp-input" autocomplete="off" />
                <span asp-validation-for="Input.PostalCode" class="text-danger small"></span>
                <div id="cp-status" class="form-text small text-muted"></div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Estado</label>
                <input value="@Model.ResolvedEstado" class="form-control" id="cp-estado"
                       readonly tabindex="-1" />
                @* StateCode se manda hidden — lo puebla el JS desde la respuesta SEPOMEX. *@
                <input type="hidden" asp-for="Input.StateCode" id="cp-estado-hidden" />
            </div>
            <div class="col-md-3">
                <label asp-for="Input.City" class="form-label">Ciudad/Municipio</label>
                <input asp-for="Input.City" class="form-control" id="cp-ciudad" readonly required />
                <span asp-validation-for="Input.City" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Input.Neighborhood" class="form-label">Colonia</label>
                <select asp-for="Input.Neighborhood" class="form-select" id="cp-colonia" required>
                    @if (string.IsNullOrWhiteSpace(Model.Input.Neighborhood) && Model.AvailableColonias.Count == 0)
                    {
                        <option value="">— Ingresa el CP —</option>
                    }
                    @foreach (var col in Model.AvailableColonias)
                    {
                        if (col == Model.Input.Neighborhood)
                        {
                            <option value="@col" selected>@col</option>
                        }
                        else
                        {
                            <option value="@col">@col</option>
                        }
                    }
                </select>
                <span asp-validation-for="Input.Neighborhood" class="text-danger small"></span>
            </div>
        </div>

        <h4 class="mt-4">Vehículo</h4>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Input.Plate" class="form-label">Placas</label>
                <input asp-for="Input.Plate" class="form-control" required />
                <span asp-validation-for="Input.Plate" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.EngineNumber" class="form-label">N° Motor</label>
                <input asp-for="Input.EngineNumber" class="form-control" required />
                <span asp-validation-for="Input.EngineNumber" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="Input.SerialNumber" class="form-label">N° Serie</label>
                <input asp-for="Input.SerialNumber" class="form-control" required />
                <span asp-validation-for="Input.SerialNumber" class="text-danger small"></span>
            </div>
        </div>

        <button type="submit" class="btn btn-success mt-4">Emitir póliza</button>
        <a class="btn btn-link" asp-page="/Index">Cancelar</a>
    </form>

    @* Muestra el alert solo si <div asp-validation-summary> rendereó errores. *@
    <script>
        (function () {
            var summary = document.querySelector('[asp-validation-summary], .validation-summary-errors');
            if (summary && summary.children.length > 0) summary.style.display = '';
        })();

        // SEPOMEX: al perder focus en el CP, consulta el servicio y autocompleta
        // Estado / Municipio / dropdown de Colonias. Si el servicio rechaza el
        // CP (404) muestra el mensaje y deja los campos como estaban.
        (function () {
            var cpInput = document.getElementById('cp-input');
            var statusBox = document.getElementById('cp-status');
            var estado = document.getElementById('cp-estado');
            var estadoHidden = document.getElementById('cp-estado-hidden');
            var ciudad = document.getElementById('cp-ciudad');
            var colonia = document.getElementById('cp-colonia');
            if (!cpInput) return;

            async function resolve() {
                var cp = cpInput.value.trim();
                if (!/^\d{5}$/.test(cp)) {
                    statusBox.textContent = '';
                    return;
                }
                statusBox.textContent = 'Consultando SEPOMEX…';
                try {
                    var resp = await fetch('?handler=ResolveCp&cp=' + encodeURIComponent(cp), {
                        headers: { 'Accept': 'application/json' }
                    });
                    var data = await resp.json();
                    if (!resp.ok || !data.ok) {
                        statusBox.textContent = data.error || 'SEPOMEX no devolvió respuesta.';
                        statusBox.classList.add('text-danger');
                        return;
                    }
                    statusBox.classList.remove('text-danger');
                    statusBox.textContent = '';
                    if (estado) estado.value = data.estado || '';
                    if (estadoHidden) estadoHidden.value = data.estado || '';
                    if (ciudad) ciudad.value = data.municipio || '';
                    if (colonia) {
                        colonia.innerHTML = '';
                        (data.asentamientos || []).forEach(function (c) {
                            var opt = document.createElement('option');
                            opt.value = c;
                            opt.textContent = c;
                            colonia.appendChild(opt);
                        });
                    }
                } catch (e) {
                    statusBox.textContent = 'Error de red al consultar SEPOMEX.';
                    statusBox.classList.add('text-danger');
                }
            }

            cpInput.addEventListener('blur', resolve);
            cpInput.addEventListener('change', resolve);
        })();
    </script>
