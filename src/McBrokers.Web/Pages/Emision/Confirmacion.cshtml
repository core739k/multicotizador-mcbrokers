@page "{emissionId:guid}"
@model McBrokers.Web.Pages.Emision.ConfirmacionModel
@{
    ViewData["Title"] = "Confirmación de emisión";
}

<h2>Póliza emitida</h2>

@if (Model.Emission is null)
{
    <div class="alert alert-warning">No encontramos la emisión.</div>
}
else
{
    <div class="card mb-3">
        <div class="card-body">
            <h5 class="card-title mb-3">
                Número de inciso:
                <span class="badge bg-primary fs-5">@Model.Emission.PolicyNumber</span>
            </h5>
            <p class="text-muted small mb-0">
                Emitida el @Model.Emission.IssuedAt?.ToLocalTime().ToString("dd/MM/yyyy HH:mm").
                El campo "inciso" lo devuelve COPSIS; confirma con tu administrador si tu
                operación lo usa como número de póliza o como ítem dentro de una póliza
                marco.
            </p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
    {
        <div class="alert alert-success">@Model.StatusMessage</div>
    }
    @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
    {
        <div class="alert alert-danger">@Model.ErrorMessage</div>
    }

    @* Visor inline. Iframe apunta al handler del propio Razor (no al endpoint
       del Api en otro puerto) para evitar problemas de CORS y poder reusar
       la misma sesión de auth de cookies. *@
    <div class="ratio ratio-4x3 mb-3" style="max-height: 70vh;">
        <iframe src="?handler=Pdf"
                title="Visor PDF de la póliza"
                style="border: 1px solid var(--bs-border-color); border-radius: .25rem;"></iframe>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-3">
        <a class="btn btn-outline-primary"
           asp-page-handler="Pdf"
           asp-route-emissionId="@Model.Emission.Id"
           asp-route-download="true">
            Descargar PDF
        </a>

        <button class="btn btn-outline-success" type="button"
                data-bs-toggle="collapse" data-bs-target="#enviarCorreoForm"
                aria-expanded="false" aria-controls="enviarCorreoForm">
            Enviar por correo
        </button>

        <a class="btn btn-link ms-auto" asp-page="/Index">Volver a cotizaciones</a>
    </div>

    <div class="collapse" id="enviarCorreoForm">
        <div class="card card-body">
            <form method="post" asp-page-handler="EnviarCorreo"
                  asp-route-emissionId="@Model.Emission.Id">
                <label asp-for="Email" class="form-label">Correo del cliente</label>
                <div class="input-group">
                    <input asp-for="Email" type="email" class="form-control" required
                           placeholder="cliente@ejemplo.com" />
                    <button type="submit" class="btn btn-success">Enviar</button>
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
                @* Mientras no integremos Microsoft Graph/SendGrid, esto solo
                   queda registrado en el log de la app (LogEmailSender). *@
                <div class="form-text">
                    Por ahora el envío real está deshabilitado — la solicitud
                    queda registrada en el log de la app y se procesará cuando
                    se habilite el proveedor de correo.
                </div>
            </form>
        </div>
    </div>
}
